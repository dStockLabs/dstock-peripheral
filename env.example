# Example environment for: script/DeployComposerRouterProxy.s.sol
#
# Usage:
#   source env.example
#   forge script script/DeployComposerRouterProxy.s.sol:DeployComposerRouterProxy --rpc-url <RPC> --broadcast -vvv
#
# Notes:
# - ADMIN_PK must be the deployer EOA private key (uint)
# - ENDPOINT_ADDRESS is LayerZero EndpointV2 address on this chain
# - CHAIN_EID is the LayerZero EID for this chain (uint32)
# - OWNER_ADDRESS is the router owner (admin) after initialize
#
# Optional verifier (no dependencies):
#   set -a && source .env && set +a
#   node scripts/checkRouteConfig.js

# Required
ADMIN_PK=
ENDPOINT_ADDRESS=0x0000000000000000000000000000000000000001
CHAIN_EID=101
OWNER_ADDRESS=0x0000000000000000000000000000000000000002

# Optional: configure routes (JSON array; one setRouteConfig call per entry)
# - Set underlying=0x0000000000000000000000000000000000000000 to ONLY register reverse mapping (shareAdapter -> wrapper)
# Tip (zsh/bash): keep JSON in single quotes to avoid escaping.
ROUTE_CONFIGS='[
  ["0x0000000000000000000000000000000000000000","0x00000000000000000000000000000000000000a0","0x00000000000000000000000000000000000000b0"],
  ["0x00000000000000000000000000000000000000c0","0x00000000000000000000000000000000000000a0","0x00000000000000000000000000000000000000b0"]
]'

# Optional: wrapped native support (enables wrapAndBridgeNative + reverse-local native delivery helper)
WRAPPED_NATIVE_ADDRESS=0x00000000000000000000000000000000000000d0
# Optional override (if unset, the script deploys a new helper using the router address)
# WRAPPED_NATIVE_PAYOUT_HELPER_ADDRESS=0x00000000000000000000000000000000000000e0

# For scripts/checkRouteConfig.js
# RPC_URL=
# ROUTER_ADDRESS=

# (Legacy env vars for route config have been removed in favor of ROUTE_CONFIGS JSON.)

