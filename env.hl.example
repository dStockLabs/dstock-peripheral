# Environment for DStockHyperCoreComposer (HyperEVM)
#
# Used by:
#   forge script script/DeployHyperCoreComposer.s.sol  (deploy)
#   node scripts/reapplyTokenConfig.js                 (apply missing token configs)
#   node scripts/checkTokenConfig.js                   (verify token configs)
#   node scripts/grantAdminRole.js                     (grant ADMIN_ROLE)
#   node scripts/revokeAdminRole.js                    (revoke ADMIN_ROLE)
#
# Usage:
#   set -a && source .env.hl && set +a
#   forge script script/DeployHyperCoreComposer.s.sol:DeployHyperCoreComposer \
#     --rpc-url $RPC_URL --legacy --broadcast -vvvv
#
# Notes:
# - DEPLOYER_PK (preferred) or ADMIN_PK: deployer EOA private key
#     DEPLOYER_PK: 0x-prefixed 32-byte hex  (e.g. 0xabc123...64hex)
#     ADMIN_PK:    integer format            (as used by forge scripts)
# - LZ_ENDPOINT:   LayerZero EndpointV2 address on HyperEVM
# - OWNER_ADDRESS: initial ADMIN_ROLE holder after initialize
# - BNB1_OFT_ADDRESS: OFT token address on HyperEVM to register via configureToken()

# ── Required ────────────────────────────────────────────────────────────────

# Deployer private key (choose one format)
DEPLOYER_PK=
# ADMIN_PK=

# HyperEVM RPC
RPC_URL=https://rpc.hyperliquid.xyz/evm

# LayerZero EndpointV2 on HyperEVM
LZ_ENDPOINT=0x3A73033C0b1407574C76BdBAc67f126f6b4a9AA9

# Router owner / initial admin
OWNER_ADDRESS=

# ── Optional: configure tokens ───────────────────────────────────────────────
# JSON array of objects; one configureToken() call per entry.
# Fields MUST be in alphabetical order: coreIndexId < decimalDiff < oft
#   coreIndexId: HyperCore spot token index (uint64)
#   decimalDiff: EVM decimals - HyperCore weiDecimals, e.g. 18-9=9 (int8, range -128~127)
#   oft:         OFT contract address on HyperEVM
#   symbol:      human-readable label (not sent on-chain, for logging/review only)
# Tip (zsh/bash): keep JSON in single quotes to avoid escaping.
TOKEN_CONFIGS='[
  {"coreIndexId": 409, "decimalDiff": 10, "oft": "0xe74aA6C4050A15790525eB11cc4562c664dC67C9", "symbol": "CRCL"},
  {"coreIndexId": 411, "decimalDiff": 10, "oft": "0x7EF4Eba0C0200957e357627CEd1884D6CB63E961", "symbol": "SLV"},
  {"coreIndexId": 412, "decimalDiff": 10, "oft": "0x35eEdA03E55FF217a013892E9e2E37E792B264EA", "symbol": "GOOGL"},
  {"coreIndexId": 413, "decimalDiff": 10, "oft": "0x7374DC1894fBD1bc6C42f6Ebbc50b78C211A8606", "symbol": "AAPL"},
  {"coreIndexId": 414, "decimalDiff": 9, "oft": "0xFD6F06D323f6CB08eE9eeB2d201e9EC0E9112c88", "symbol": "BNB1"},
  {"coreIndexId": 415, "decimalDiff": 9, "oft": "0xc304a9d52CF9165024EBc7814250EF3A5013F924", "symbol": "HOOD"},
  {"coreIndexId": 417, "decimalDiff": 9, "oft": "0x8E4E0B4b1b073f1e97e2724B42612998c039FCA4", "symbol": "MSTR"},
  {"coreIndexId": 420, "decimalDiff": 9, "oft": "0xB7bF37783DB41A2851B77c6917280c56312C833a", "symbol": "SPY"},
  {"coreIndexId": 421, "decimalDiff": 9, "oft": "0x4F2164C12D2d450A8B1D430492Ef6670FE4caD8e", "symbol": "AMZN"},
  {"coreIndexId": 422, "decimalDiff": 9, "oft": "0x5A9D2DeeE7D8782011695623f1C453F46B2b566e", "symbol": "META"},
  {"coreIndexId": 426, "decimalDiff": 9, "oft": "0x499e347174f237AD28687B947B94C0d49570D1b7", "symbol": "QQQ"},
  {"coreIndexId": 429, "decimalDiff": 9, "oft": "0x66520d8Fd614487214a25Af7bAbF27584f59f76B", "symbol": "MSFT"},
  {"coreIndexId": 432, "decimalDiff": 9, "oft": "0x08be08c37D93E689518CED744A89F113b4AfAad4", "symbol": "GLD"}
]'


# ── Post-deploy ─────────────────────────────────────────────────────────────
# Used by:
#   scripts/reapplyTokenConfig.js  - apply missing configureToken calls (uses DEPLOYER_PK for signing)
#   scripts/checkTokenConfig.js    - verify token configs on-chain (read-only)
#   scripts/grantAdminRole.js      - grant ADMIN_ROLE
#   scripts/revokeAdminRole.js     - revoke ADMIN_ROLE

COMPOSER_ADDRESS=              # deployed proxy address (set after deployment)
# MULTISIG_ADDRESS=          # address to grant ADMIN_ROLE (grantAdminRole.js)
# TARGET_ADDRESS=            # address to revoke ADMIN_ROLE from (revokeAdminRole.js)
# GAS_PRICE=3gwei
# LEGACY_TX=1
# DRY_RUN=1                  # print commands without executing (reapplyTokenConfig.js)
